# Plaid (https://dashboard.plaid.com/account/keys)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Server
PORT=3001

# Phone auth (Twilio Verify: https://console.twilio.com/us1/develop/verify/services)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# JWT signing (use a long random string in production)
JWT_SECRET=change-me-in-production
